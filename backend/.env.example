# Copy to .env and adjust. compose reads this file via env_file/--env-file.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS (프론트엔드 클라이언트 허용) ---
# DEBUG=True 면 기본적으로 모든 오리진을 허용한다(개발 편의). 운영에서는 비워 두고
# CORS_ALLOWED_ORIGINS 에 정확한 오리진만 나열한다.
CORS_ALLOW_ALL_ORIGINS=
# 쉼표로 구분. 미설정 시 Vite 개발/프리뷰 서버(5173·4173)를 기본 허용.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173
# 세션/쿠키 인증을 붙이기 전까지는 false 유지.
CORS_ALLOW_CREDENTIALS=False

# --- Postgres ---
POSTGRES_DB=tabllet
POSTGRES_USER=tabllet
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Host port the backend is published on (compose only).
BACKEND_PORT=8000

# --- External services ---
# OCR server (이미지 -> 약물명 JSON). Base URL or IP:port, no trailing slash.
OCR_SERVER_URL=http://127.0.0.1:9001
# LLM 정제 서버 (HIRA 주의사항 -> 구조화 JSON). Base URL or IP:port.
LLM_SERVER_URL=http://127.0.0.1:9002
# Timeout (seconds) for outbound OCR/LLM/HIRA requests.
EXTERNAL_HTTP_TIMEOUT=30

# --- HIRA / MFDS DrugPrdtPrmsnInfoService (data.go.kr) ---
# 공공데이터포털에서 발급받은 서비스키(보안키). URL 인코딩 전/후 어느 쪽이든 허용.
HIRA_API_KEY=
# 의약품 제품 허가정보 상세조회 엔드포인트 (보통 그대로 사용).
HIRA_BASE_URL=https://apis.data.go.kr/1471000/DrugPrdtPrmsnInfoService07/getDrugPrdtPrmsnDtlInq06
# 로컬 캐시 파일 경로 (reference/hira_res.json에서 시드됨).
HIRA_CACHE_PATH=/app/data/hira_res.json
